# Copia este archivo a .env.local. El entorno de desarrollo es el proyecto
# remoto de Supabase (mkrsicuvhnmljpurtwun) — ver docs/DECISIONS.md. Saca los
# valores reales del dashboard (Project Settings → API) — no pegues aquí claves reales.

NEXT_PUBLIC_SUPABASE_URL=https://mkrsicuvhnmljpurtwun.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<dashboard: Project Settings → API → anon/publishable key>
SUPABASE_SERVICE_ROLE_KEY=<dashboard: Project Settings → API → service_role/secret key — usado por /api/cron/send-notifications (bloque 2.2)>

# Supabase local (`supabase start`) sigue disponible para tests que requieren
# aislamiento (ver rls-isolation.test.ts / permissions.test.ts) — usa un
# .env.test.local aparte apuntando a http://127.0.0.1:54321 si necesitas correrlos.

# Opcional: sin esta clave, las invitaciones por email loguean el enlace en la
# consola del servidor en vez de enviarlo (ver src/features/auth/email.ts).
RESEND_API_KEY=

# Google OAuth aplazado al bloque 4.2 (docs/TASKS.md). El código ya existe;
# el botón queda oculto hasta entonces. No poner "true" antes de 4.2.
NEXT_PUBLIC_FEATURE_GOOGLE_OAUTH=false

# Bloque 2.2 (canales de alertas): secreto compartido que
# /api/cron/send-notifications exige en el header X-Cron-Secret. Debe
# coincidir EXACTAMENTE con el GUC app.settings.cron_secret configurado en el
# proyecto remoto de Supabase (ver el comentario de cabecera de
# supabase/migrations/0016_notification_channels.sql) — Postgres no puede
# leer este archivo, así que ambos valores se mantienen en sync a mano.
CRON_SECRET=

# URL pública de esta app, usada para construir los deep-links reales de las
# alertas de renovación (email/Teams). Debe coincidir con el GUC
# app.settings.site_url del mismo proyecto remoto por el mismo motivo.
NEXT_PUBLIC_SITE_URL=https://saascostchecker-production.up.railway.app
