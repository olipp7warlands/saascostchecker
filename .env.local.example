# Copia este archivo a .env.local. Los valores reales salen de `supabase status`
# tras `supabase start` (cambian por máquina) — no pegues aquí claves reales.

NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=<supabase status: Publishable key>
SUPABASE_SERVICE_ROLE_KEY=<supabase status: Secret key>

# Proyecto remoto (Fase 0.2+): enlazado con `supabase link --project-ref mkrsicuvhnmljpurtwun`.
# Para desarrollo local, deja las URLs/keys de arriba (instancia local). Las del
# proyecto remoto solo se usan en despliegue (Vercel), sacadas del dashboard de Supabase.

# Opcional: sin esta clave, las invitaciones por email loguean el enlace en la
# consola del servidor en vez de enviarlo (ver src/features/auth/email.ts).
RESEND_API_KEY=
