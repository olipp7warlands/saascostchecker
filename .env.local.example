# Copia este archivo a .env.local. Los valores reales salen de `supabase status`
# tras `supabase start` (cambian por máquina) — no pegues aquí claves reales.

NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=<supabase status: Publishable key>
SUPABASE_SERVICE_ROLE_KEY=<supabase status: Secret key>

# Proyecto remoto (Fase 0.2+): pendiente de `supabase link --project-ref <ref>`.
# Cuando exista, añade aquí la URL y claves del proyecto de Supabase en la nube.
